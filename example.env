MQTT_BROKER=localhost
MQTT_PORT=1883

DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True

DECISION_INTERVAL_MINUTES=3

BATTERY_LAG_INTERVAL_SECONDS=30


MAX_BATTERY_DROP_PERCENT=2

# Nighttime battery drop threshold (%) — wider to prevent false positives
# when there is no solar recharge (4PM–10:59AM).
MAX_BATTERY_DROP_NIGHT_PERCENT=8

# Solar window (24h). Daytime profile applies from SOLAR_HOUR_START
# to SOLAR_HOUR_END-1 (inclusive). Outside this window → nighttime profile.
SOLAR_HOUR_START=11
SOLAR_HOUR_END=16


MODE_A_MAX_KWH=2.4


# ─── Data Simulator ──────────────────────────────────────────────
# Used by: simulation/data_simulator.py
# Base URL of the ML FastAPI prediction service.
ML_API_BASE=http://127.0.0.1:5000

# Max seconds to wait for a prediction on MQTT before timing out.
PREDICTION_TIMEOUT=30

# Minimum seconds to pause between CSV rows (keeps output readable).
#   Set to 0 to go as fast as possible (prediction-paced only).
MIN_ROW_DELAY=3

# Battery drain mode: "consistent" (linear -0.1%/row) or "inconsistent"
#   (randomised fluctuations to stress-test the 3-time battery lag).
BATTERY_DRAIN_MODE=inconsistent

# Starting battery percentage when the simulator boots.
BATTERY_START=85.0

# Minimum battery percentage — drain stops here.
BATTERY_FLOOR=20.0


# ─── ML Prediction API ───────────────────────────────────────────
# Used by: test_prediction_api.py
# Peak demand threshold (mirrored from rule engine for contract sync).
PEAK_DEMAND_KW=2.4
