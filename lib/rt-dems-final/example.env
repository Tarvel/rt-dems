MQTT_BROKER=localhost
MQTT_PORT=1883

DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True

DECISION_INTERVAL_MINUTES=3

BATTERY_LAG_INTERVAL_SECONDS=30


MAX_BATTERY_DROP_PERCENT=2


MODE_A_MAX_KWH=2.4


RELAY_PIN_1=17
RELAY_PIN_2=27
RELAY_PIN_3=22


# ─── Data Simulator ──────────────────────────────────────────────
# Used by: simulation/data_simulator.py
# Base URL of the ML FastAPI prediction service.
ML_API_BASE=http://127.0.0.1:5000

# Max seconds to wait for a prediction on MQTT before timing out.
PREDICTION_TIMEOUT=30

# Minimum seconds to pause between CSV rows (keeps output readable).
#   Set to 0 to go as fast as possible (prediction-paced only).
MIN_ROW_DELAY=3


# ─── ML Prediction API ───────────────────────────────────────────
# Used by: test_prediction_api.py
# Peak demand threshold (mirrored from rule engine for contract sync).
PEAK_DEMAND_KW=2.4
